    {
      "name": "Books \u2014 Add",
      "description": "POST /api/v1/books (multipart) and GraphQL addBook. Depends on token captured by the Auth folder's signup test.",
      "item": [
        {
          "name": "POST /api/v1/books \u2014 happy path (201)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "The Hobbit",
                  "type": "text"
                },
                {
                  "key": "author",
                  "value": "J. R. R. Tolkien",
                  "type": "text"
                },
                {
                  "key": "year_published",
                  "value": "1937",
                  "type": "text"
                },
                {
                  "key": "cover",
                  "type": "file",
                  "src": "fixtures/cover.jpg"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/books",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "books"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('returns book.id', () => pm.expect(body.book.id).to.be.a('string'));",
                  "pm.test('returns book.title', () => pm.expect(body.book.title).to.eql('The Hobbit'));",
                  "pm.test('returns book.author', () => pm.expect(body.book.author).to.eql('J. R. R. Tolkien'));",
                  "pm.test('returns book.year_published', () => pm.expect(body.book.year_published).to.eql(1937));",
                  "pm.test('returns Available status', () => pm.expect(body.book.status).to.eql('Available'));",
                  "pm.test('cover_object_key looks right', () => pm.expect(body.book.cover_object_key).to.match(/^covers\\//));",
                  "pm.test('owner_id matches caller', () => pm.expect(body.book.owner_id).to.eql(pm.collectionVariables.get('userId')));",
                  "pm.collectionVariables.set('createdBookId', body.book.id);"
                ]
              }
            }
          ]
        },
