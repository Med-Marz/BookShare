# === Auth ===
JWT_SECRET=replace-me-with-a-long-random-string

# === Gateway / frontend ===
WEB_ORIGIN=http://localhost:8080
VITE_GATEWAY_URL=http://localhost:4000

# === Per-service gRPC ports ===
USER_GRPC_PORT=50051
BOOK_GRPC_PORT=50052
LOAN_GRPC_PORT=50053
NOTIFICATION_GRPC_PORT=50054

# === Per-service /health ports (HTTP inside containers; mapped only for debug) ===
USER_HEALTH_PORT=50061
BOOK_HEALTH_PORT=50062
LOAN_HEALTH_PORT=50063
NOTIFICATION_HEALTH_PORT=50064

# === Database paths inside containers (mapped to named Docker volumes) ===
USER_DB_PATH=/app/data/user.sqlite
LOAN_DB_PATH=/app/data/loan.sqlite
NOTIFICATION_DB_PATH=/app/data/notification.sqlite
BOOK_SNAPSHOT_PATH=/app/data/books.snapshot.json

# === Kafka ===
KAFKA_BROKERS=kafka:9092

# === MinIO ===
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=bookshare-admin
MINIO_SECRET_KEY=bookshare-admin-secret-change-me
MINIO_BUCKET=bookshare-covers

# === Logging ===
LOG_LEVEL=info
NODE_ENV=development
