            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\": \"mutation Add($input: AddBookInput!) { addBook(input: $input) { id title author year_published cover_object_key status owner_id } }\", \"variables\": {\"input\": {\"title\": \"Dune\", \"author\": \"Frank Herbert\", \"year_published\": 1965, \"cover_base64\": \"__COVER_B64__\", \"cover_content_type\": \"image/jpeg\"}}}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Postman doesn't read files from disk in pre-request, so use a baked-in tiny base64 jpeg.",
                  "// 358-byte solid-color JPEG (matches postman/fixtures/cover.jpg).",
                  "const tinyJpegBase64 = '';",
                  "const body = JSON.parse(pm.request.body.raw);",
                  "body.variables.input.cover_base64 = tinyJpegBase64;",
                  "pm.request.body.update(JSON.stringify(body));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('no errors', () => pm.expect(body.errors).to.be.undefined);",
                  "pm.test('returns addBook.id', () => pm.expect(body.data.addBook.id).to.be.a('string'));",
                  "pm.test('returns Dune title', () => pm.expect(body.data.addBook.title).to.eql('Dune'));",
                  "pm.test('returns Available status', () => pm.expect(body.data.addBook.status).to.eql('Available'));"
                ]
              }
            }
          ]
        },
