{
  "info": {
    "name": "BookShare",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "BookShare REST + GraphQL test collection. Grows story by story. Run with `newman run postman/BookShare.postman_collection.json` for CI-style verification."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Signup, login, logout. Story 1.2 introduces signup; 1.3 adds login + logout.",
      "item": [
        {
          "name": "POST /auth/signup — happy path",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/signup", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "signup"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice+{{$timestamp}}@example.com\",\n  \"password\": \"correctbattery\",\n  \"display_name\": \"Alice\",\n  \"phone\": \"+216 22 000 000\",\n  \"address\": \"Tunis, Tunisia\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('returns a token', () => pm.expect(body.token).to.be.a('string').and.not.empty);",
                  "pm.test('returns user.id', () => pm.expect(body.user.id).to.be.a('string'));",
                  "pm.test('returns user.email', () => pm.expect(body.user.email).to.be.a('string'));",
                  "pm.test('returns user.display_name', () => pm.expect(body.user.display_name).to.be.a('string'));",
                  "pm.collectionVariables.set('token', body.token);",
                  "pm.collectionVariables.set('userId', body.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/signup — duplicate email (409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/signup", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "signup"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"duplicate@example.com\",\n  \"password\": \"correctbattery\",\n  \"display_name\": \"First\",\n  \"phone\": \"+216 22 000 001\",\n  \"address\": \"Sfax\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Run the request twice in sequence — second one should 409.",
                  "// Newman runs requests once each; for an end-to-end newman run, run /auth/signup happy path twice.",
                  "// Here we accept 201 (first time) or 409 (subsequent).",
                  "pm.test('status is 201 or 409', () => pm.expect(pm.response.code).to.be.oneOf([201, 409]));",
                  "if (pm.response.code === 409) {",
                  "  const body = pm.response.json();",
                  "  pm.test('error.code is CONFLICT', () => pm.expect(body.error.code).to.eql('CONFLICT'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/signup — short password (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/signup", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "signup"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"short@example.com\",\n  \"password\": \"short\",\n  \"display_name\": \"Shorty\",\n  \"phone\": \"+216 22 000 002\",\n  \"address\": \"Tunis\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 400', () => pm.response.to.have.status(400));",
                  "const body = pm.response.json();",
                  "pm.test('error.code is VALIDATION_ERROR', () => pm.expect(body.error.code).to.eql('VALIDATION_ERROR'));",
                  "pm.test('message mentions password', () => pm.expect(body.error.message.toLowerCase()).to.include('password'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "GraphQL",
      "description": "Signup mutation via the /graphql endpoint.",
      "item": [
        {
          "name": "mutation signup — happy path",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/graphql", "host": ["{{baseUrl}}"], "path": ["graphql"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation Signup($input: SignupInput!) { signup(input: $input) { token user { id email display_name } } }\",\n  \"variables\": {\n    \"input\": {\n      \"email\": \"gql+{{$timestamp}}@example.com\",\n      \"password\": \"correctbattery\",\n      \"display_name\": \"GraphQL User\",\n      \"phone\": \"+216 22 100 000\",\n      \"address\": \"Tunis\"\n    }\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('no GraphQL errors', () => pm.expect(body.errors).to.be.undefined);",
                  "pm.test('returns token', () => pm.expect(body.data.signup.token).to.be.a('string'));",
                  "pm.test('returns user.id', () => pm.expect(body.data.signup.user.id).to.be.a('string'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
